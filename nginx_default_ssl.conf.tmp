server {
    listen 80;
    server_name 72roll.ru www.72roll.ru;

    # ACME Challenge for Let's Encrypt
    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    # Redirect all HTTP traffic to HTTPS
    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl;
    server_name 72roll.ru www.72roll.ru;

    ssl_certificate /etc/letsencrypt/live/72roll.ru/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/72roll.ru/privkey.pem;

    client_max_body_size 50M;

    # Backend API
    location /api {
        proxy_pass http://foodtech-backend:8000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Admin Panel (Laravel)
    location /admin {
        root /var/www/html/admin/public;
        index index.php index.html;
        try_files $uri $uri/ /admin/index.php?$query_string;

        location ~ \.php$ {
            include fastcgi_params;
            fastcgi_param SCRIPT_FILENAME /var/www/html/public/index.php;
            fastcgi_pass foodtech-admin:9000;
            fastcgi_param REQUEST_URI /admin$request_uri;
            fastcgi_param APP_URL https://72roll.ru/admin;
        }
    }

    # Frontend (Built SPA on port 80)
    location / {
        proxy_pass http://foodtech-frontend:80;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }
}
