import re
import os

def replace_method(content, class_name, method_name, new_method_content):
    # Find the class
    class_regex = rf"class {class_name}.*?:"
    class_match = re.search(class_regex, content, re.DOTALL)
    if not class_match:
        print(f"Class {class_name} not found")
        return content
    
    # Find the method inside the class
    # This is tricky because of indentation.
    method_regex = rf"([ ]+)async def {method_name}\(self, .*?\):.*?(?=\n[ ]+async def|\n[ ]+def|\n\n|\Z)"
    
    # Let's use a simpler approach for these specific files
    if method_name == "sync_menu":
        # From 'async def sync_menu' to before 'async def sync_prices'
        pattern = r"    async def sync_menu\(self, session: Session\) -> Dict\[str, Any\]:.*?    async def sync_prices"
        content = re.sub(pattern, new_method_content + "\n\n    async def sync_prices", content, flags=re.DOTALL)
    elif method_name == "process_iiko_order":
        # From 'async def process_iiko_order' to before 'async def sync_order_by_id'
        pattern = r"    async def process_iiko_order\(self, session: Session,.*?    async def sync_order_by_id"
        content = re.sub(pattern, new_method_content + "\n\n    async def sync_order_by_id", content, flags=re.DOTALL)
        
    return content

